        "end": 3.6540000000000004,
        "words": []
      },
      {
        "text": "European exercise.",
        "start": 3.654,
        "end": 5.69,
        "words": []
      },
      {
        "text": "Cash settled.",
        "start": 5.69,
        "end": 6.726,
        "words": []
      },
      {
        "text": "No shares change hands, just money.",
        "start": 6.726,
        "end": 9.238,
        "words": []
      }
    ]
  },
  {
    "id": "C1-8",
    "durationFrames": 135,
    "audioSrc": "voiceover/edge/C1-8.mp3",
    "sentences": [
      {
        "text": "But I'm not going to lecture you.",
