        "end": 1.392,
        "words": []
      },
      {
        "text": "I'm going to let you live it.",
        "start": 1.392,
        "end": 2.619,
        "words": []
      },
      {
        "text": "We built a trading desk you can play.",
        "start": 2.619,
        "end": 4.464,
        "words": []
      }
    ]
  },
  {
    "id": "C1-9",
    "durationFrames": 153,
    "audioSrc": "voiceover/edge/C1-9.mp3",
    "sentences": [
      {
        "text": "Real accounts.",
        "start": 0.05,
        "end": 1.119,
        "words": []
      },
      {
        "text": "Real progress tracking.",
        "start": 1.119,
        "end": 2.7139999999999995,
        "words": []
      },
      {
        "text": "Four days from rookie to closer.",
        "start": 2.714,
        "end": 5.035,
        "words": []
      }
    ]
  },
  {
    "id": "C1-10",
    "durationFrames": 68,
    "audioSrc": "voiceover/edge/C1-10.mp3",
    "sentences": [
      {
        "text": "Day one starts now.",
        "start": 0.05,
        "end": 1.149,
