    "audioSrc": "voiceover/edge/C1-1.mp3",
    "sentences": [
      {
        "text": "October, nineteen ninety-seven.",
        "start": 0.05,
        "end": 2.723,
        "words": []
      }
    ]
  },
  {
    "id": "C1-2",
    "durationFrames": 163,
    "audioSrc": "voiceover/edge/C1-2.mp3",
    "sentences": [
      {
        "text": "In four trading days, the Hang Seng Index loses twenty-three percent of its value.",
        "start": 0.05,
        "end": 5.364,
        "words": []
      }
    ]
  },
  {
    "id": "C1-3",
    "durationFrames": 186,
    "audioSrc": "voiceover/edge/C1-3.mp3",
    "sentences": [
      {
        "text": "Overnight interest rates jump from eight percent to twenty-three.",
        "start": 0.05,
        "end": 4.071,
        "words": []
      },
      {
        "text": "At one point, two hundred and eighty.",
        "start": 4.071,
        "end": 6.154,
        "words": []
      }
    ]
  },
  {
    "id": "C1-4",
    "durationFrames": 196,
    "audioSrc": "voiceover/edge/C1-4.mp3",
    "sentences": [
      {
        "text": "And while everyone else is panicking, somebody on that trading floor is making money.",
        "start": 0.05,
        "end": 4.436,
        "words": []
      },
      {
        "text": "Hi!",
        "start": 4.436,
        "end": 5.056,
        "words": []
      },
      {
        "text": "I'm Jordan Bull.",
        "start": 5.056,
        "end": 6.463,
        "words": []
      }
    ]
  },
  {
    "id": "C1-5",
    "durationFrames": 155,
    "audioSrc": "voiceover/edge/C1-5.mp3",
    "sentences": [
      {
        "text": "I'm going to show you the only product that turns panic...",
        "start": 0.05,
        "end": 3.3138571428571426,
        "words": []
      },
      {
        "text": "into a paycheck.",
        "start": 3.3138571428571426,
        "end": 4.204,
        "words": []
      },
      {
        "text": "Options!",
        "start": 4.204,
        "end": 5.09,
        "words": []
      }
    ]
  },
  {
    "id": "C1-6",
    "durationFrames": 270,
    "audioSrc": "voiceover/edge/C1-6.mp3",
    "sentences": [
      {
        "text": "This is the Hang Seng Index Option.",
        "start": 0.05,
        "end": 2.214,
        "words": []
      },
      {
        "text": "Listed on the Hong Kong exchange since March, nineteen ninety-three.",
        "start": 2.214,
        "end": 6.464,
        "words": []
      },
      {
        "text": "The flagship index derivative of Asia.",
        "start": 6.464,
        "end": 8.94,
        "words": []
      }
    ]
  },
  {
    "id": "C1-7",
    "durationFrames": 279,
    "audioSrc": "voiceover/edge/C1-7.mp3",
    "sentences": [
      {
        "text": "Every point of the index is worth fifty Hong Kong dollars.",
